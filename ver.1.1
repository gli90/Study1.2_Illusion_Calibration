from psychopy import visual, core, event, gui
from psychopy.hardware import keyboard
import numpy as np
import pandas as pd
import random

# =====================================================
# Study 1.2 Pilot v1.1
# Color matching task
# Nulling for illusion calibration
#
# Author:
# Gong Li
